# ── Variables de entorno requeridas para producción (T24) ──────────────────────
# Copia este archivo a `.env.local` para desarrollo local.
# En Vercel: Settings → Environment Variables → añadir una por una.

# URL pública del sitio (para OG, sitemap, canonical, CORS)
NEXT_PUBLIC_SITE_URL=https://tu-subdominio.vercel.app

# Resend (https://resend.com) — clave de API para envío de emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email de destino del formulario de contacto (dominio verificado en Resend)
CONTACT_EMAIL=tu@dominio.com

# Upstash Redis / Vercel KV — rate-limit del formulario de contacto
# Obtener desde: https://console.upstash.com → tu DB → REST API
KV_REST_API_URL=https://xxxxxxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Opcionales ─────────────────────────────────────────────────────────────────
# Token de la GitHub App de Lighthouse CI (para comentarios en PRs)
# LHCI_GITHUB_APP_TOKEN=
